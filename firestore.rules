rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function validProfile(profile) {
      return profile is map
        && profile.keys().hasOnly(['displayName'])
        && profile.displayName is string
        && profile.displayName.size() <= 40;
    }

    function validSession(session) {
      return session is map
        && session.keys().hasOnly(['activeSessionId', 'updatedAtMs'])
        && session.activeSessionId is string
        && session.activeSessionId.size() <= 120
        && session.updatedAtMs is number;
    }

    match /users/{uid} {
      allow read: if isOwner(uid);

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'email',
          'role',
          'profile',
          'session',
          'createdAt',
          'updatedAt',
          'saveData'
        ])
        && request.resource.data.email is string
        && request.resource.data.role == 'player'
        && validProfile(request.resource.data.profile)
        && validSession(request.resource.data.session)
        && request.resource.data.saveData == null;

      allow update: if isOwner(uid)
        && request.resource.data.keys().hasOnly([
          'email',
          'role',
          'profile',
          'session',
          'createdAt',
          'updatedAt',
          'saveData'
        ])
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'profile',
          'session',
          'updatedAt'
        ])
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.saveData == resource.data.saveData
        && validProfile(request.resource.data.profile)
        && validSession(request.resource.data.session);

      allow delete: if false;
    }

    match /publicPlayers/{uid} {
      allow read: if true;
      allow write: if false;
    }
  }
}
